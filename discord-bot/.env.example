# Discord 机器人配置
# 复制此文件为 .env 并填入真实值

# === 必填 ===
DISCORD_TOKEN=your_bot_token_here

# === AI 功能 (可选，不填则禁用 AI) ===
OPENAI_API_KEY=sk-your_key_here
OPENAI_MODEL=gpt-4o-mini
# 系统提示词
SYSTEM_PROMPT=你是一个友好、乐于助人的 Discord 机器人助手。

# === 基础设置 ===
COMMAND_PREFIX=!

# === 管理 ===
# 所有者 Discord ID，多个用逗号分隔
OWNER_IDS=123456789012345678

# === 频道 ===
# 日志频道 ID
LOG_CHANNEL_ID=
# 欢迎频道 ID（新成员加入时发送欢迎消息）
WELCOME_CHANNEL_ID=
# AI 自动回复频道 ID，多个用逗号分隔
AI_CHANNEL_IDS=

# === 欢迎消息 ===
# 可用变量: {user} {server}
WELCOME_MESSAGE=欢迎 {user} 加入 {server}！🎉

# === 审核 ===
AUTO_MODERATE=true
# 违禁词，逗号分隔
BANNED_WORDS=
