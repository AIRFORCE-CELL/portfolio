# ── 服务配置 ──────────────────────────
API_KEY=dev-key-change-me
HOST=0.0.0.0
PORT=8000

# ── 数据库 ────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/scraper.db

# ── 采集设置 ──────────────────────────
DEFAULT_TIMEOUT=30
MAX_CONCURRENT=5
USER_AGENT=Mozilla/5.0 (compatible; ScraperBot/1.0)
RESPECT_ROBOTS=true

# ── 缓存（可选）────────────────────────
# REDIS_URL=redis://localhost:6379/0

# ── 浏览器渲染（需要 playwright 已安装）──
USE_BROWSER=true
HEADLESS=true
