# Scraper API 配置
# 复制为 .env 并修改

API_KEY=dev-key-change-me
HOST=0.0.0.0
PORT=8000

# 采集设置
DEFAULT_TIMEOUT=30
MAX_CONCURRENT=5
USER_AGENT=Mozilla/5.0 (compatible; ScraperBot/1.0)
RESPECT_ROBOTS=true

# 浏览器渲染 (需要 playwright)
USE_BROWSER=false
HEADLESS=true

# 数据库
DATABASE_URL=sqlite+aiosqlite:///./data/scraper.db

# 缓存 (可选)
# REDIS_URL=redis://localhost:6379
