# ── 必需 ──────────────────────────────
DISCORD_TOKEN=your_bot_token_here

# ── 基本配置 ──────────────────────────
COMMAND_PREFIX=!

# ── AI 对话（可选，不填则 AI 功能关闭）───
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# AI 自动回复的频道 ID，用逗号分隔
AI_CHANNEL_IDS=
# 系统提示词
SYSTEM_PROMPT=你是一个友好、乐于助人的 Discord 机器人助手。

# ── 管理员配置 ────────────────────────
# 机器人主人的 Discord 用户 ID，逗号分隔
OWNER_IDS=
# 日志频道 ID（成员加入/离开通知）
LOG_CHANNEL_ID=
# 欢迎频道 ID
WELCOME_CHANNEL_ID=
WELCOME_MESSAGE=欢迎 {user} 加入 {server}！

# ── 内容审核 ──────────────────────────
# 违禁词，逗号分隔
BANNED_WORDS=
AUTO_MODERATE=true
